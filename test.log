	key = $.trim(key.replace(/"/g,''));
	msg = msg.replace(/^"/,'').replace(/"$/,'');
	
	//.replace(/'/g, "\\'")
	
	var data = '<div class="flash-message-98523 flash-message '+key+'" id="'+key+'">'+msg+'</div>';
	$('#flash_from_js_98523').after(data);
	
	// Optional: jQueryUI effects
	if(msg.search(/denied/i) > -1) {
		$('#'+key+'.flash-message-98523').delay(5000).fadeOut();
	}
	
	if(key == 'flash_error_fixed_to_top') {
		window.setTimeout(function() { $('#'+key).fadeOut(3000); }, 10000);
	}
	
	
	// Now delete them.  (this was set from AccessComponent::setFlash())
	$.removeCookie('elstats_flash_message',{domain:'.electionstats.state.ma.us',path:'/'});
	$.removeCookie('elstats_flash_key',{domain:'.electionstats.state.ma.us',path:'/'});
	
